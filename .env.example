# Copie este arquivo para .env.local e preencha com os dados do SEU projeto Supabase
# (Painel do Supabase > Project Settings > API)

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anonima-aqui

# Opcional - só quando for configurar a IA (camada gratuita)
GROQ_API_KEY=

# Opcional - só quando for configurar o WhatsApp Cloud API (camada gratuita)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
